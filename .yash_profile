######################
#Default Applications#
######################

export BROWSER='flatpak run com.brave.Browser'
export CALCULATOR='bc -q'
export EDITOR='micro'
export FILEPICKER='yad --file'
export MAIL='flatpak run eu.betterbird.Betterbird'
export MIXER='pulsemixer'
export OFFICE='flatpak run org.onlyoffice.desktopeditors'
export PLAYER='flatpak run io.mpv.Mpv'
export TASKMANAGER='btop'
export TERMEXEC='flatpak run org.contourterminal.Contour'
export TERMINAL='flatpak run org.contourterminal.Contour'

###########
#Distrobox#
###########

export DBX_CONTAINER_CUSTOM_HOME='$HOME/.var/home/aaron'
export DBX_CONTAINER_IMAGE='quay.io/toolbx-images/debian-toolbox:unstable'
export DBX_CONTAINER_MANAGER='podman'
export DBX_CONTAINER_NAME='siderius'

##########################
#Organize XDG Directories#
##########################

# Cache
export XDG_CACHE_HOME="$HOME"/.cache

# Config
export XDG_CONFIG_HOME="$HOME"/.config

# Data
export XDG_DATA_HOME="$HOME"/.local/share

# X11
export ALTUSERXSESSION="$XDG_CACHE_HOME"/X11/Xsession
export ERRFILE="$XDG_CACHE_HOME/X11"/xsession-errors
export USERXSESSION="$XDG_CACHE_HOME"/X11/xsession
export USERXSESSIONRC="$XDG_CACHE_HOME"/X11/xsessionrc
export XINITRC="$XDG_CONFIG_HOME"/X11/xinitrc
export XRESOURCES="$XDG_CONFIG_HOME"/X11/xresources

# WM
export CWMRC="$XDG_CONFIG_HOME"/cwm/.cwmrc

######
#Path#
######

if [ -d "$HOME/.bin" ] ;
  then PATH="$HOME/.bin:$PATH"
fi

if [ -d "$HOME/.local/bin" ] ;
  then PATH="$HOME/.local/bin:$PATH"
fi

############################
#Single-User Cursor Theming#
############################

export XCURSOR_PATH=${XCURSOR_PATH}:~/.local/share/icons

######################################
#Treat the TTY Like a Display Manager#
######################################

if [ -z "${DISPLAY}" ] && [ "${XDG_VTNR}" -eq 1 ]; then
  exec startx $XINITRC
fi
