### General settings
general {
  output_format = "i3bar"
  colors = true
  color_good = "#00FF00"
  color_bad = "#FF0000"
  color_degraded = "#FFFF00"
  interval = 1
}

order += "ethernet _first_"
order += "wireless _first_"
order += "run_watch TOR"
order += "cpu_temperature all"
order += "load"
order += "disk /"
order += "memory"
order += "volume master"
order += "time"

ethernet _first_ {
    format_up = "E:%speed"
    format_down = "E:DOWN"
}

wireless _first_ {
    format_up = "W:%bitrate"
    format_down = "W:DOWN"
}

run_watch TOR {
    format = "%title:%status"
    pidfile = "/var/run/tor/tor.pid"
}

cpu_temperature all {
	format = "TEMP:%degrees°C"
}

load {
    format = "LOAD:%1min"
}

disk "/" {
	format = "DISK:%used/%avail/%total"
	prefix_type = custom
	low_threshold = 20
	threshold_type = percentage_avail
}

memory {
    format = "MEM:%used/%free/%available"
    threshold_degraded = "1G"
    format_degraded = "MEM:%available"
}

volume master {
  format = "%devicename:%volume"
  format_muted = "%devicename:MUTED"
  device = "default"
  mixer = "Master"
  mixer_idx = 0
}

time {
  format = "%c"
}
