#############################################################
# Basic controls for focusing, ignoring, or killing windows #
#############################################################

control + super + i
 ignw -s $(pfw)

control + super + Delete
 killw $(pfw)

super + f
 nowm_focus.sh last

super + {_,shift + }Tab
 {nowm_focus.sh prev,nowm_focus.sh next}


############################
# Window grouping keychain #
############################

control + super + m ; {a,s,w}
 {nowm_mapw.sh add, \
  nowm_mapw.sh stogle, \
  nowm_mapw.sh wtogle}

##########################
# Window layout keychain #
##########################

control + super + l ; {c,m,s,t}
 {nowm_layout.sh cascade, \
  nowm_layout.sh monocule, \
  nowm_layout.sh split, \
  nowm_layout.sh tiling}

##############################
# Window moving and resizing #
##############################

super + {h,j,k,l}
 wmv {-10 0,0 10,0 -10,10 0} $(pfw)
	
super + {KP_7,KP_9,KP_1,KP_3}
 wmv -a {0 0,1280 0,0 800,1280 800} $(pfw)

alt + super {h,l,k,j}
 {wrs -10 0 $(pfw), \
  wrs 10 0 $(pfw), \
  wrs 0 -10 $(pfw), \
  wrs 0 10 $(pfw)}

