# Common Application Shortcuts      #
#####################################

super + Return
 uxterm

XF86Calculator
 xcalc

XF86Homepage
 librewolf

XF86Mail
 thunderbird

###########
# Editors #
###########

super + e ; {n,v}
 {uxterm -e nano, \
  uxterm -e $EDITOR}

#########################
# Launcher              #
#########################
# Requires UXTerm/XTerm #
#########################

super + Menu
 xlauncher.sh

#######################
# Multimedia Controls #
#######################

XF86Audio{LowerVolume,RaiseVolume,Mute}
 {amixer sset Master 10%-, \
  amixer sset Master 10%+, \
  amixer sset Master toggle}

XF86Tools
 uxterm -e alsamixer

#################
# Restart SXHKD #
#################

super + Escape
 pkill -USR1 -x sxhkd

