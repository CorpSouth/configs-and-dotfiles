#################################
# refresh the $HOME/.zshrc file #
#################################

alias szsh='source $XDG_CONFIG_HOME/zsh/.zshrc'

##############
# ls aliases #
##############

alias ls='ls --color=auto'

###################################################
# safeguards to prevent total devastation of data #
###################################################

alias cp='cp -n'
alias mv='mv -n'
alias rm='rm -i --preserve-root'

#######################################
# rpm-ostree (ostree distro-specific) #
#######################################

alias apply-live='rpm-ostree install --apply-live'
alias cleanall='rpm-ostree cleanup -bmr'
alias cleanup'rpm-ostree cleanup -bm'
alias install='rpm-ostree install'
alias pin0='sudo ostree admin pin 0'
alias rollback='rpm-ostree rollback'
alias status='rpm-ostree status'
alias uninstall='rpm-ostree uninstall'
alias update='rpm-ostree update'
