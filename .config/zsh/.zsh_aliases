#################################
# refresh the $HOME/.zshrc file #
#################################

alias szsh='source $XDG_CONFIG_HOME/zsh/.zshrc'

###################
# SUMMON THE FIGS #
###################

alias figs='$EDITOR $XDG_CONFIG_HOME'

##############
# ls aliases #
##############

alias ls='ls --color=auto'

###########
# YouTube #
###########

alias yt-dlp-update="doas yt-dlp -U"
alias yta-aac="yt-dlp --extract-audio --audio-format aac "
alias yta-best="yt-dlp --extract-audio --audio-format best "
alias yta-flac="yt-dlp --extract-audio --audio-format flac "
alias yta-mp3="yt-dlp --extract-audio --audio-format mp3 "
alias ytv-best="yt-dlp -f 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/bestvideo+bestaudio' --merge-output-format mp4 "

###################################################
# safeguards to prevent total devastation of data #
###################################################

alias rm='rm -i --preserve-root'
alias cp='cp -n'
alias mv='mv -n'

#################################################################################
# aliases to help facilitate GUI application launching from the command line    #
#################################################################################
# One way to launch GUI applications from the command line is through nohup,    #
# also known as no-hangup, which detaches the child process from the parent.    #
# This method isn't perfect due to the command littering $HOME with a nohup.out #
# logfile every time. A solution is to use a prefixing script in a shell alias  #
# which I have titled "x", containing only the necessary string for detaching   #
# the child process from the parent. It is shell-agnostic and should work with  #
# non-POSIX compliant shells. Put the script in your $PATH and prefix an alias  #
# of your choosing. Here are the contents of the shell script below:            #
#################################################################################
#                                                                               #
# '#!/bin/sh                                                                    #
#  $(nohup "$@" >/dev/null 2>&1 & kill -KILL $PPID) &'                          #
#                                                                               #
#################################################################################
# In addition to the above script, I have created an alternative version that   #
# uses "setsid" with the "-f" or "fork" option, named "x0". It can substitute   #
# "x" in the event of nohup prematurely timing out for some programs, since it  #
# excludes SIGHUP system calls whereas nohup simply ignores any instances.      #
# Here are the contents of the alternate shell script below:                    #
#################################################################################
#                                                                               #
# '#!/bin/sh                                                                    #
#  $(setsid -f "$@" >/dev/null 2>&1; kill -KILL $PPID)'                         #
#                                                                               #
#################################################################################

alias bleachbit="x bleachbit"
alias bleachbit-root="x bleachbit"
alias cmake-gui="x cmake-gui"
alias eos-apps-info="x eos-apps-info"
alias eos-log-tool="x eos-log-tool"
alias firewall-config="x firewall-config"
alias libfm-pref-apps="x libfm-pref-apps"
alias libreoffice-base="x libreoffice --base"
alias libreoffice-calc="x libreoffice --calc"
alias libreoffice-draw="x libreoffice --draw"
alias libreoffice-impress="x libreoffice --impress"
alias libreoffice-math="x libreoffice --math"
alias libreoffice-writer="x libreoffice --writer"
alias librewolf="x librewolf"
alias lxappearance="x lxappearance"
alias lxappearance-root="doas x lxappearance"
alias mpv-gui="x mpv --player-operation-mode=pseudo-gui"
alias pcmanfm="x pcmanfm"
alias pcmanfm-root="doas x pcmanfm"
alias picom="x picom"
alias telegram-desktop="x telegram-desktop"
alias thunderbird="x thunderbird"
alias usbimager="x usbimager"
alias webcord="x webcord-3.2.0-arm64.AppImage"
alias xarchiver="x xarchiver"
