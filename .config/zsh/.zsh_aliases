#################################
# refresh the $HOME/.zshrc file #
#################################

alias szsh='source $XDG_CONFIG_HOME/zsh/.zshrc'

###################
# SUMMON THE FIGS #
###################

alias figs='$EDITOR $XDG_CONFIG_HOME'

##############
# ls aliases #
##############

alias ls='ls --color=auto'

###########
# YouTube #
###########

alias yt-dlp-update="doas yt-dlp -U"
alias yta-aac="yt-dlp --extract-audio --audio-format aac "
alias yta-best="yt-dlp --extract-audio --audio-format best "
alias yta-flac="yt-dlp --extract-audio --audio-format flac "
alias yta-mp3="yt-dlp --extract-audio --audio-format mp3 "
alias ytv-best="yt-dlp -f 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/bestvideo+bestaudio' --merge-output-format mp4 "

###################################################
# safeguards to prevent total devastation of data #
###################################################

alias rm='rm -i --preserve-root'
alias cp='cp -n'
alias mv='mv -n'

#################################################################################
# aliases to help facilitate GUI application launching from the command line    #
#################################################################################
# One way to launch GUI applications from the command line is through nohup,    #
# also known as no-hangup, which detaches the child process from the parent.    #
# This method isn't perfect due to the command littering $HOME with a nohup.out #
# logfile every time. A solution is to use a prefixing script in a shell alias  #
# which I have titled "x", containing only the necessary string for detaching   #
# the child process from the parent. It is shell-agnostic and should work with  #
# non-POSIX compliant shells. Put the script in your $PATH and prefix an alias  #
# of your choosing. Here are the contents of the shell script below:            #
#################################################################################
#                                                                               #
# '#!/bin/sh                                                                    #
#  nohup "$@" >/dev/null 2>&1 &'                                                #
#                                                                               #
#################################################################################

alias bleachbit="x bleachbit; clear"
alias bleachbit-root="doas x bleachbit; clear"
alias cmake-gui="x cmake-gui; clear"
alias eos-apps-info="x eos-apps-info; clear"
alias eos-log-tool="x eos-log-tool; clear"
alias eos-update-notifier-configure="x eos-update-notifier-configure; clear"
alias firewall-config="x firewall-config; clear"
alias libfm-pref-apps="x libfm-pref-apps; clear"
alias libreoffice-base="x libreoffice --base; clear"
alias libreoffice-calc="x libreoffice --calc; clear"
alias libreoffice-draw="x libreoffice --draw; clear"
alias libreoffice-impress="x libreoffice --impress; clear"
alias libreoffice-math="x libreoffice --math; clear"
alias libreoffice-writer="x libreoffice --writer; clear"
alias librewolf="x librewolf; clear"
alias lxappearance="x lxappearance; clear"
alias lxappearance-root=" doas x lxshortcut; clear"
alias mpv-gui="x mpv --player-operation-mode=pseudo-gui; clear"
alias pcmanfm="x pcmanfm; clear"
alias pcmanfm-root="doas x pcmanfm; clear"
alias picom="x picom; clear"
alias telegram-desktop="x telegram-desktop; clear"
alias thunderbird="x thunderbird; clear"
alias webcord="x webcord-3.2.0-arm64.AppImage; clear"
alias xarchiver="x xarchiver; clear"
