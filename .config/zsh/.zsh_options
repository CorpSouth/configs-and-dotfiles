################################################
# custom prompt                                #
################################################

PROMPT="%B%F{green}%<<%2~ %f%b"

#########
# fetch #
#########

PF_INFO="editor kernel memory os pkgs shell uptime wm palette" /usr/bin/pfetch

################################
# emulate the following shells #
################################

#if [ -n "$ZSH_VERSION" ]; then emulate -L sh; fi

##############
# setoptions #
##############

setopt autocd ALWAYS_TO_END COMPLETE_IN_WORD correct extendedglob interactive_comments menucomplete MULTI_OS nomatch

################
# unsetoptions #
################

unsetopt BEEP

###########
# history #
###########

HISTORY_IGNORE="figs|szsh|x|x0"
HISTSIZE=1000
SAVEHIST=1000
HISTFILE="$XDG_DATA_HOME/zsh/.zsh_history"
LESSHISTFILE=-
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_DUPS
setopt HIST_REDUCE_BLANKS
