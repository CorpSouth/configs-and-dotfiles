####################################
# place all 'zstyle' prefixes here #
####################################
# completions                      #
####################################

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*' 

#####################
# persistent rehash #
#####################

zstyle ':completion:*' rehash true

