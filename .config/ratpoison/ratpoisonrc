###########################
#Welcome to the Ratslayer!#
###########################

# Autostart

exec /usr/bin/rpws init 5 -k

# Borders

set barborder 1
set border 1

# Colors

set bgcolor #3B3E3F
set bwcolor #2F3133
set fgcolor #FFFFFF
set fwcolor #145BA6

# Font

set font Iosevka:size=16:style=Extended,Regular

# Geometry

set barinpadding 5 5
set barpadding 8 8

# Gravity

set bargravity center
set transgravity center

# Startup Message

set startupmessage 0

# WM: Escape Key

escape Super_L

# WM: Execute Command

bind Menu exec
bind M-Menu colon exec x-terminal-emulator -e 

# WM: Focus Next and Previous Windows

bind M-Tab prev
bind Tab next

# WM: Switch Next and Previous Workspace

bind bracketleft exec rpws prev
bind bracketright exec rpws next

# WM: Switch to Specific Workspaces

bind 1 exec rpws 1
bind 2 exec rpws 2
bind 3 exec rpws 3
bind 4 exec rpws 4
bind 5 exec rpws 5

# WM: Unbind/Undefine Keys

unbind C-exclam
unbind C-n
unbind C-p
unbind C-space
unbind exclam
unbind N
unbind n
unbind P
unbind p
unbind space
