#!/bin/sh

####################
# autohide xcursor #
####################

xbanish -t 5 &

###############################
# invoke the policykit daemon #
###############################

/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

####################################
# launch system monitoring utility #
####################################

sleep 2 &&
uxterm -e btop &

###############################
# run the lock screen manager #
###############################

xautolock -time 10 -locker slock &

#####################
# reload xresources #
#####################

xrdb -merge $XRESOURCES &

#####################
# set the wallpaper #
#####################

xwallpaper --stretch $XDG_DATA_HOME/wallpapers/eos-minimal.png &

#################################
# start the compositing manager #
#################################

sleep 2 &&
picom &

######################
# start the xsession #
######################

exec openbox
