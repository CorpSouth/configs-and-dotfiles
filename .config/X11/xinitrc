#!/bin/sh

####################
# background color #
####################

hsetroot -solid "#241F31" &

#####################################
# picom display compositing manager #
#####################################

picom &

############################
# simple x11 hotkey daemon #
############################

sxhkd &

######################################
# virtual machine display correction #
######################################

/usr/bin/spice-vdagent &

sleep 2 &&
xrandr -s 1600x900 &

####################
# xcursor settings #
####################

xsetroot -cursor_name left_ptr &

##############
# xresources #
##############

xrdb -merge $XRESOURCES &

############
# xsession #
############

exec focusd.sh
