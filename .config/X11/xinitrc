#!/bin/sh

############################
# set virtual monitor size #
############################

xrandr -s 1600x900 &

####################
# autohide xcursor #
####################

xbanish -t 5 &

###############################
# invoke the policykit daemon #
###############################

/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

###############################
# run the lock screen manager #
###############################

xautolock -time 10 -locker slock &

#####################
# reload xresources #
#####################

xrdb -merge $XRESOURCES &

#####################
# set the wallpaper #
#####################

xwallpaper --stretch $XDG_DATA_HOME/wallpapers/DebianArt/Emerald-wallpaper_1920x1080.png &

#################################
# start the compositing manager #
#################################

sleep 2 &&
picom &

######################
# start the xsession #
######################

exec cwm -c /home/corpsouth/.config/cwm/.cwmrc
