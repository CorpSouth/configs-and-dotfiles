*.color10:     col10
*.color11:     col11
*.color12:     col12
*.color13:     col13
*.color14:     col14
*.color15:     col15
*.colorBD:     col15

! Xft
Xft*antialias: true 
Xft*hinting:   true 
Xft*hintstyle: hintnone
Xft*lcdfilter: lcddefault
Xft*rgba:      rgb

! URxvt
URxvt*font:              xft:Ubuntu Mono:size=12
URxvt*boldfont:          xft:Ubuntu Mono:size=12:style=bold
URxvt*italicfont:        xft:Ubuntu Mono:size=12:style=italic
URxvt*bolditalicfont:    xft:Ubuntu Mono:size=12:style=bolditalic
URxvt*cursorBlink:       true
URxvt*cursorUnderline:   true
URxvt.iso14755:          false
URxvt.iso14755_52:       false
!URxvt*letterSpace:       1
!URxvt*lineSpace:         1
URxvt*scrollWithBuffer:   true 
URxvt*scrollTtyOutput:   false
URxvt*scrollTtyKeypress: true
URxvt*scrollBar:         false
URxvt*scrollBar_right:   false
URxvt*secondaryScreen:   1
URxvt*secondaryScroll:   0
URxvt*internalBorder:    12 
URxvt*urgentOnBell:      true

! URxvt Perl Extensions
Urxvt.perl-ext-common: resize-font

! URxvt keybinds for copy/pasting
URxvt.keysym.Shift-Control-V: eval:paste_clipboard
URxvt.keysym.Shift-Control-C: eval:selection_to_clipboard

! URxvt keybinds for changing text size on the fly
URxvt.keysym.C-Down: resize-font:smaller
URxvt.keysym.C-Up:   resize-font:bigger
