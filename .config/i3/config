################
# {} \|||||||  # Welcome to my i3wm configuration file!
#           || #
# []        || # For a bigger picture on what to do here,
# []  |||||||  # refer to https://i3wm.org
# []        || #
# []        || # This file is not a complete representation
# [] /|||||||  # of all of i3's features
################

# Autostart programs

exec_always --no-startup-id $TERMINAL -name btop -e btop

exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id hsetroot -solid "#000000"
exec --no-startup-id picom
exec --no-startup-id xbanish -t 5
exec --no-startup-id xautolock -time 10 -locker slock
exec --no-startup-id dunst
exec --no-startup-id xrdb -merge $XRESOURCES

# Modifier
set $mod Mod4
floating_modifier $mod

# Terminal emulator
bindsym $mod+Return      exec --no-startup-id $TERMINAL
bindsym $mod+Mod1+Return exec --no-startup-id $TERMINAL -name scratchpad

# Terminal scratchpad
bindsym Mod1+Return $scratchpad

# Print the screen
bindsym $mod+Print exec --no-startup-id scrot  ~/.local/share/screenshots/%c.png

# Directional keys (Vi-like)
set $up    k
set $down  j
set $left  h
set $right l

# Colors (XTerm)
# Using variables makes referencing colors across your configuration easier

set $black         #000000
set $dimgray       #7F7F7F
set $gray          #E5E5E5
set $white         #FFFFFF
set $brightred     #FF0000
set $red           #CD0000
set $brightgreen   #00FF00
set $green         #00CD00
set $brightyellow  #FFFF00
set $yellow        #CDCD00
set $brightblue    #5C5CFF
set $blue          #0000EE
set $brightmagenta #FF00FF
set $magenta       #CD00CD
set $brightcyan    #00FFFF
set $cyan          #00CDCD

# Disable title bars and allow enabling of gaps
for_window [class="^.*"] border pixel 2

# Disable borders when there's only one window
smart_borders on

# Disable gaps when there's only one window
smart_gaps on

# Fonts are either in pango or xft
font pango: Iosevka Term Extended

# Align the window title center, left (default), or right
title_align center

# In order: class, border, background, indicator, child border
client.focused          $brightgreen  $green  $black $brightmagenta $green
client.focused_inactive $brightcyan   $cyan   $black $magenta       $cyan
client.unfocused        $brightblue   $blue   $black $magenta       $blue
client.urgent           $brightyellow $yellow $red   $brightred     $yellow
client.placeholder      $dimgray      $gray   $black $white         $dimgray
client.background       $black

# Bar

# NOTICE:
# If you are starting your i3wm configuration from scratch,
# please set up your workspace variables beforehand or ALL
# options will simply result in error

bar {
    status_command i3status
    # If you only want the workspace name, set to "yes"
    strip_workspace_numbers yes
    # Obey Fitt's law
    tray_padding 0
    colors {
           background $black
           separator  $dimgray       
           statusline $gray
           # In order: border, background, text
           focused_workspace  $brightgreen   $green   $black
           active_workspace   $brightcyan    $cyan    $black
           inactive_workspace $brightblue    $blue    $black
           urgent_workspace   $brightyellow  $yellow  $brightred
           binding_mode       $brightmagenta $magenta $black
    }
}

# Workspace variables
set $ws1 "1:.net"
set $ws2 "2:chat"
set $ws3 "3:load"
set $ws4 "4:play"
set $ws5 "5:util"
set $ws6 "6:work"
set $ws7 "7:virt"

# Workspace assignments (use xprop to grab window information)

# Assign by class
assign [class="librewolf-default|thunderbird"]      $ws1
assign [class="discord|Telegram"]                   $ws2
assign [class="FreeTube|mpv|Steam"]                 $ws4
assign [class="Com.github.tchx84.Flatseal|Pcmanfm"] $ws5
assign [class="Soffice"]                            $ws6
assign [class="Virt-manager"]                       $ws7
assign [instance="btop|htop|top"]                   $ws3

# Go to workspace
bindsym $mod+bracketleft  workspace prev
bindsym $mod+bracketright workspace next
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7

# Focus on window opening
focus_on_window_activation focus

# Focal keybindings (Vi-like)
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right

# Focal toggle
bindsym $mod+f focus mode_toggle

# Tabular focus
bindsym $mod+Tab       focus next
bindsym $mod+shift+Tab focus prev

# Kill window
bindsym $mod+control+Delete kill

# Menus and run launchers
bindsym $mod+Menu exec --no-startup-id i3-dmenu-desktop
bindsym Mod1+Menu exec --no-startup-id dmenu_run

# XF86 common
bindsym XF86Calculator exec --no-startup-id xcalc
bindsym XF86Explorer   exec --no-startup-id pcmanfm
bindsym XF86HomePage   exec --no-startup-id librewolf
bindsym XF86Mail       exec --no-startup-id thunderbird

# XF86 media
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +1%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -1%
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86Tools            exec --no-startup-id $TERMINAL -name alsamixer -e alsamixer

# Set the following rule to make a generic scratchpad terminal
for_window [instance="scratchpad"] move scratchpad, scratchpad show, resize set 1000 750, move position center

# Scratchpad rules
for_window [instance="alsamixer|pavucontrol"] move scratchpad, scratchpad show, resize set 1000 750, move position center

# Scratchpad the current window
bindsym $mod+control+grave move scratchpad

# Toggle the scratchpad
bindsym $mod+grave scratchpad show

# Toggle split (pre-select) direction
bindsym $mod+s         split toggle
bindsym $mod+control+s layout toggle split 

# Float rules
for_window [class="XCalc|XClock"] floating enable
for_window [title="About LibreWolf|Friends List|Settings"] floating enable, move position center

# Layout rules for stacking containers
for_window [class="discord|Telegram"] layout stacked

# Layout rules for tabbed containers
for_window [class="librewolf-default|thunderbird"] layout tabbed
for_window [instance="btop"] layout tabbed

# Layout changing
mode "layout" {
              bindsym d layout default
              bindsym f floating toggle
              bindsym s layout stacking
              bindsym t layout tabbed
              #exit the mode
              bindsym Escape mode "default"
              bindsym Return mode "default"
}
bindsym $mod+Mod1+l mode "layout"

# Move-resize
mode "move-resize" {
                   # Move
                   bindsym $left  move left
                   bindsym $down  move down
                   bindsym $up    move up
                   bindsym $right move right
		   bindsym c move position center
                   # Resize
                   bindsym Left  resize shrink width  1 px or 1 ppt
                   bindsym Down  resize grow height   1 px or 1 ppt
                   bindsym Up    resize shrink height 1 px or 1 ppt
                   bindsym Right resize grow width    1 px or 1 ppt
                   # Exit mode
                   bindsym Escape mode "default"
                   bindsym Return mode "default"
}
bindsym $mod+control+m mode "move-resize"

# Session & power
mode "session & power" {
                       # Logout, Lock, Reboot, Reload, Restart i3, Shutdown, and Suspend
	               bindsym c  reload
                       bindsym End pkill -KILL -u $USER
                       bindsym F5 restart
	               bindsym Pause slock
                       bindsym p systemctl poweroff
                       bindsym r systemctl reboot
                       bindsym s systemctl suspend
                       # Exit mode
                       bindsym Escape mode "default"
                       bindsym Return mode "default"
}
bindsym $mod+End mode "session & power"
