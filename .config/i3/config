# Autostart programs

exec --no-startup-id xrdb -merge $XRESOURCES
exec_always --no-startup-id $TERMINAL -name btop -e btop
exec --no-startup-id hsetroot -center $XDG_DATA_HOME/wallpapers/thestruggle.png
exec --no-startup-id picom
exec --no-startup-id xbanish -t 5
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock-with-dpms 
exec --no-startup-id dunst
exec --no-startup-id xfce4-clipman
exec --no-startup-id nm-applet
exec --no-startup-id pasystray

# Modifier
set $mod Mod4
floating_modifier $mod

# Terminal emulator
bindsym $mod+Return      exec --no-startup-id $TERMINAL
bindsym $mod+Mod1+Return exec --no-startup-id $TERMINAL -name scratchpad

# Start a container session
bindsym $mod+KP_Enter exec --no-startup-id $TERMINAL -name scratchpad -e toolbox enter fedora-toolbox-38

# Terminal scratchpad
bindsym Mod1+Return $scratchpad

# Print the screen
bindsym Print exec --no-startup-id scrot  $HOME/.local/share/screenshots/%c.png

# Directional keys (Vi-like)
set $up    k
set $down  j
set $left  h
set $right l

# Colors (XTerm)
set $black0    #000000
set $red1      #CD0000
set $green2    #00CD00
set $yellow3   #CDCD00
set $blue4     #0000EE
set $magenta5  #CD00CD
set $cyan6     #00CDCD
set $gray7     #E5E5E5
set $gray8     #7F7F7F
set $red9      #FF0000
set $green10   #00FF00
set $yellow11  #FFFF00
set $blue12    #5C5CFF
set $magenta13 #FF00FF
set $cyan14    #00FFFF
set $white15   #FFFFFF

# Disable title bars and allow enabling of gaps
for_window [class="^.*"] border pixel 3

# Disable borders when there's only one window
smart_borders on

# Disable gaps when there's only one window
smart_gaps on

# Fonts are either in pango or xft
font pango: Iosevka Term Extended

# Align the window title center, left (default), or right
title_align center

# In order: class, border, background, indicator, child border
client.focused          $cyan14   $cyan6   $black0 $cyan14  $cyan6
client.focused_inactive $blue12   $blue4   $black0 $blue12  $blue4
client.unfocused        $gray7    $gray8   $black0 $white15 $gray8
client.urgent           $yellow11 $yellow3 $red1   $red9    $yellow3
client.placeholder      $white15  $black0  $gray7  $red1    $white15
client.background       $black0

# Bar
bar {
    status_command i3status
    # If you only want the workspace name, set to "yes"
    strip_workspace_numbers yes
    # Obey Fitt's law
    tray_padding 0
    colors {
           background $black0
           separator  $gray8       
           statusline $gray7
           # In order: border, background, text
           focused_workspace  $green10   $green2   $black0
           active_workspace   $blue12    $blue4    $black0
           inactive_workspace $gray7     $gray8    $black0
           urgent_workspace   $red9      $yellow3  $red1
           binding_mode       $magenta13 $magenta5 $black0
    }
}

# Workspace variables
set $ws1 "1:.net"
set $ws2 "2:chat"
set $ws3 "3:load"
set $ws4 "4:play"
set $ws5 "5:util"
set $ws6 "6:work"
set $ws7 "7:virt"

# Workspace assignments (use xprop to grab window information)

# Assign by class
assign [class="librewolf-default|thunderbird"]      $ws1
assign [class="discord|Telegram"]                   $ws2
assign [class="FreeTube|mpv|Steam"]                 $ws4
assign [class="Com.github.tchx84.Flatseal|Thunar"] $ws5
assign [class="Soffice"]                            $ws6
assign [class="Virt-manager"]                       $ws7
assign [instance="btop|htop|top"]                   $ws3

# Go to workspace
bindsym $mod+bracketleft  workspace prev
bindsym $mod+bracketright workspace next
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7

# Switch back and forth from the most recent two workspaces
workspace_auto_back_and_forth yes

# Focus on window opening
focus_on_window_activation focus
for_window [urgent=latest] focus

# Focal keybindings (Vi-like)
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right

# Focal toggle
bindsym $mod+f focus mode_toggle

# Tabular focus
bindsym $mod+Tab       focus next
bindsym $mod+shift+Tab focus prev

# Kill window
bindsym $mod+control+Delete kill

# Menus and run launchers
bindsym $mod+Menu exec --no-startup-id i3-dmenu-desktop
bindsym Mod1+Menu exec --no-startup-id dmenu_run

# XF86 common
bindsym XF86Calculator exec --no-startup-id xcalc
bindsym XF86Explorer   exec --no-startup-id thunar
bindsym XF86HomePage   exec --no-startup-id librewolf
bindsym XF86Mail       exec --no-startup-id thunderbird

# XF86 media
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10%
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86Tools            exec --no-startup-id $TERMINAL -name scratchpad -e alsamixer

# Set the following rule to make a generic scratchpad terminal
for_window [instance="scratchpad"] move scratchpad, scratchpad show, resize set 1125 750, move position center, sticky enable

# Scratchpad rules
for_window [class="Pavucontrol"] move scratchpad, scratchpad show, resize set 1025 850, move position center, sticky enable

# Scratchpad the current window
bindsym $mod+control+grave move scratchpad

# Toggle the scratchpad
bindsym $mod+grave scratchpad show

# Toggle split (pre-select) direction
bindsym $mod+s         split toggle
bindsym $mod+control+s layout toggle split 

# Float rules
for_window [class="XCalc|XClock"] floating enable
for_window [title="About LibreWolf|Friends List|Settings"] floating enable, move position center

# Layout rules for stacking containers
for_window [class="discord|Telegram"] layout stacked

# Layout rules for tabbed containers
for_window [class="librewolf-default|thunderbird"] layout tabbed
for_window [instance="btop"] layout tabbed

# Layout changing
mode "layout" {
              bindsym d layout default
              bindsym f floating toggle
              bindsym s layout stacking
              bindsym t layout tabbed
              #exit the mode
              bindsym Escape mode "default"
              bindsym Return mode "default"
}
bindsym $mod+control+l mode "layout"

# Move-resize
mode "move-resize" {
                   # Move
                   bindsym $left  move left
                   bindsym $down  move down
                   bindsym $up    move up
                   bindsym $right move right
		   bindsym c move position center
                   # Resize
                   bindsym Left  resize shrink width  1 px or 1 ppt
                   bindsym Down  resize grow height   1 px or 1 ppt
                   bindsym Up    resize shrink height 1 px or 1 ppt
                   bindsym Right resize grow width    1 px or 1 ppt
                   # Exit mode
                   bindsym Escape mode "default"
                   bindsym Return mode "default"
}
bindsym $mod+control+m mode "move-resize"

# Session & power
mode "session & power" {
                       # Logout, Lock, Reboot, Reload, Restart, Shutdown, and Suspend
	               bindsym c  reload
                       bindsym End exec pkill -KILL -u $USER
                       bindsym F5 restart
	               bindsym Pause exec i3lock-with-dpms 
                       bindsym p exec systemctl poweroff
                       bindsym r exec systemctl reboot
                       bindsym s exec systemctl suspend
                       # Exit mode
                       bindsym Escape mode "default"
                       bindsym Return mode "default"
}
bindsym $mod+End mode "session & power"
