###########
#Autostart#
###########

exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id dunst
exec --no-startup-id picom
exec --no-startup-id xautolock -time 10 -locker slock
exec --no-startup-id xrandr -s 1600x900
exec --no-startup-id xrdb -merge ~/.xresources

#######
#Decor#
#######

font pango:Iosevka SS12 Extended Extra Light 8
for_window [class="^.*"] border pixel 2
smart_borders on
title_align center

# In order of lines: Class,  Border, Background, Text, Indicator, Child Border
client.focused          #1C1C1C #8C5DD9 #FFFFFF #73D216 #8C5DD9
client.focused_inactive #1C1C1C #5828A8 #DADADA #73D216 #5828A8
client.unfocused        #1C1C1C #2B2B2B #A7A7A7 #73D216 #1C1C1C
client.urgent           #FC4138 #F27835 #000000 #FC4138 #F27835
client.placeholder      #1C1C1C #2B2B2B #DADADA #2B2B2B #2B2B2B
client.background       #2B2B2B

##########
#Defaults#
##########

for_window [class="^.*"] layout tabbed
set $mod Mod4
floating_modifier $mod
tiling_drag modifier titlebar

#######
#Focus#
#######

for_window [urgent=latest] focus

#######
#Float#
#######

# By class

# By instance

# By role
for_window [window_role="GtkFileChooserDialog"] resize set 65 65, move position center

# By title

##############################################################
#Key modes: These prevent cross-program keybinding conflicts,#
#abuse these if you worry about conflicting keybindings      #
##############################################################

# Execute programs, use the keyboard as an application launcher
bindsym Control+e mode "e"
mode "e" {
         bindsym b exec --no-startup-id betterbird
         bindsym Control+p exec --no-startup-id uxterm -name BTOP++ -e btop
         bindsym d exec --no-startup-id discord
         bindsym f exec --no-startup-id freetube
         bindsym l exec --no-startup-id librewolf
         bindsym o exec --no-startup-id soffice
         # Scratchpad
         bindsym $mod+grave exec --no-startup-id uxterm -name scratchpad
         # Terminal Emulator
         bindsym Return exec --no-startup-id i3-sensible-terminal
         bindsym Return mode "default"
         bindsym Escape mode "default"         
}

# Manage the focus and placement of windows, switch workspaces, etc. 
bindsym control+m mode "m"
mode "m" {
         # Focus (vi)
         bindsym h focus left
         bindsym j focus down
         bindsym k focus up
         bindsym l focus right
         bindsym Control+Delete kill
         # Focus (tabular)
         bindsym Tab focus next
         bindsym Shift+Tab focus prev
         # Focus switching between floating and tiled windows
         bindsym Mod1+f focus mode_toggle
         # Layouts
         bindsym Control+s layout toggle split
         bindsym Control+t split toggle
         bindsym d layout default
         bindsym f floating toggle
         bindsym s layout stacked
         bindsym t layout tabbed
         # Moving
         bindsym Shift+h move left
         bindsym Shift+j move down
         bindsym Shift+k move up
         bindsym Shift+l move right
         # Resize
         bindsym Control+h resize shrink width 5 px or 5 ppt
         bindsym Control+j resize grow height 5 px or 5 ppt
         bindsym Control+k resize shrink height 5 px or 5 ppt
         bindsym Control+l resize grow width 5 px or 5 ppt
         # Send container/window to workspace
         bindsym Shift+1 move container to workspace number $ws1
         bindsym Shift+1 move container to workspace number $ws2
         bindsym Shift+1 move container to workspace number $ws3
         bindsym Shift+1 move container to workspace number $ws4
         bindsym Shift+1 move container to workspace number $ws5
         bindsym Shift+1 move container to workspace number $ws6
         # Switch to workspace (next/prev)
         bindsym bracketleft workspace prev
         bindsym bracketright workspace next
         # Switch to workspace (1-9)
         bindsym 1 workspace number $ws1
         bindsym 2 workspace number $ws2
         bindsym 3 workspace number $ws3
         bindsym 4 workspace number $ws4
         bindsym 5 workspace number $ws5
         bindsym 6 workspace number $ws6
         # Exit mode
         bindsym Return mode "default"
         bindsym Escape mode "default"
}

# Session management
bindsym Control+End mode "s"
mode "s" {
         # i3
         bindsym e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
         bindsym Mod1+r restart
         bindsym r reload
         # Power
         bindsym Control+Mod1+End exec --no-startup-id systemctl poweroff
         bindsym Control+Mod1+F5 exec --no-startup-id systemctl reboot
         bindsym Control+Mod1+Pause exec --no-startup-id slock
}

############
#Scratchpad#
############

for_window [instance="scratchpad"] move window to scratchpad, scratchpad show, resize set 1125 750, move position center, sticky enable
bindsym $mod+grave scratchpad show

############
#Workspaces#
############

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"

# By class
assign [class="betterbird|LibreWolf"] $ws1
assign [class="discord|TelegramDesktop"] $ws2
assign [class="FreeTube|mpv"] $ws3

# By instance
assign [instance="BTOP++"] $ws4

# By title
assign [title="(?i)LibreOffice.*"] $ws6
