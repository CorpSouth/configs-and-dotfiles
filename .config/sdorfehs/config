##########################################
#WINDOW MANAGEMENT KEYBINDINGS BEGIN HERE#
###############################################
#Banish the Xcursor to the bottom-right corner#
################################################
#NOTE: Programs like xbanish automatically hide#
#the xcursor for you, but doing so can get rid###
#of useful features, like waitcursor on keymap.#
#changing.######################################
###########

definekey top C-s-b banish

##########################################
#Correct, Delete, Kill, Remove, & Restore#
##########################################

bind C-Delete remove
bind Delete delete
bind M-Delete kill
bind o only
bind R redo
bind r redisplay
bind U undo

#############
#Information#
#############

definekey information c curframe
definekey information Escape abort
definekey information i info
definekey information t title
definekey information v vscreens
definekey information w windows

########
#Moving#
########

bind at vmove

###########
#Selection#
###########

bind S select

###########
#Splitting#
###########

bind h hsplit
bind v vsplit

#################
#Sticky/Unsticky#
#################

bind asterisk stick
bind M-asterisk unstick

##################
#Switching (Root)#
##################

bind braceleft prevscreen
bind braceright nextscreen
bind bracketleft prev
bind bracketright next
bind C cprev
bind c cnext
bind i inext
bind M-c cother
bind M-i iprev
bind S swap

#################
#Switching (Top)#
#################

definekey top s-0 vselect 0
definekey top s-1 vselect 1
definekey top s-2 vselect 2
definekey top s-3 vselect 3
definekey top s-4 vselect 4

