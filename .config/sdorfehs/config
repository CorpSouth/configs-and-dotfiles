bind s-E editor
bind s-O office
bind s-T telegram-desktop
bind s-t exec $TERMINAL
bind s-u exec sdorfehs -c "echo `uname -a`"
bind s-Y youtube

#############
#Lock Screen#
#############

bind Pause exec slock

