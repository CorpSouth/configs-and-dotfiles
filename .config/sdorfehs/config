unbind C-s
unbind C-space
unbind C-underscore
unbind C-u
unbind C-v
unbind C-w
unbind C-x
unbind colon
unbind exclam
unbind F1
unbind F2
unbind F3
unbind F4
unbind F5
unbind F6
unbind F7
unbind F8
unbind F9
unbind F10
unbind F11
unbind F12
unbind F
unbind f
unbind k
unbind K
unbind l
unbind M-v
unbind m
unbind N
unbind n
unbind P
unbind p
unbind Q
unbind question
unbind Return
unbind space
unbind s
unbind u
unbind w
unbind x

#####################
#UNBINDING ENDS HERE#
######################
#UNMANAGE BEGINS HERE#
######################

unmanage mpv
unmanage OpenSSH Authentication Passphrase Request

####################
#UNMANAGE ENDS HERE#
##############################
#VSCREEN RENAMING BEGINS HERE#
##############################

vselect 0
vrename BrowserMail
vselect 1
vrename Communications
vselect 2
vrename Entertainment
vselect 3
vrename Productivity
vselect 4
vrename Utilities
vselect 0

##################
#XF86 BEGINS HERE#
###################
#XF86 Common (Top)#
###################

definekey top XF86Calculator exec $TERMEXEC $CALCULATOR
definekey top XF86Explorer exec $FILEPICKER
definekey top XF86HomePage exec $BROWSER
definekey top XF86Mail exec $MAIL

#######################
#XF86 Multimedia (Top)#
#######################

definekey top M-XF86Tools exec $TERMEXEC $MIXER
definekey top XF86Tools exec $PLAYER
definekey top XF86AudioLowerVolume voldown
definekey top XF86AudioMute volmute
definekey top XF86AudioRaiseVolume volup

