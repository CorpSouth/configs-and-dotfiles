###########################################
#Welcome to Sdorfehs! Refer to the manpage#
#for additional configuration options.#####
#######################################
#ADDHOOKS BEGIN HERE#
##################################
#Attach Commands to Random Events#
########################################
#Give me a Rundown of Available Windows#
#After I Have Switched Focus############
#############################

addhook switchframe windows
addhook switchwin windows

#############################
#Tell Me Which Screen I'm On#
#############################

addhook switchvscreen vscreens

###################
#ADDHOOKS END HERE#
####################
#ALIASES BEGIN HERE#
################################################
#Useful for stringing together complex commands#
##################################################################
#Dependencies: Volnoti script requires dunst and pulseaudio-utils#
##################################################################
#Variables ("$") have been provided in $HOME/.yash_profile# 
###########################################################

alias browser exec sdorfehs -c "vselect 0" -c "exec $BROWSER"
alias calculator exec sdorfehs -c "vselect 4" -c "exec $TERMEXEC $CALCULATOR"
alias discord exec sdorfehs -c "vselect 1" -c "exec $DISCLIENT"
alias echodate exec sdorfehs -c "echo `date`"
alias echouname exec sdorfehs -c "echo `uname -a`"
alias editor exec sdorfehs -c "vselect 4" -c "exec $TERMEXEC $EDITOR"
alias email exec sdorfehs -c "vselect 0" -c "exec $MAIL"
alias filepicker exec $FILEPICKER
alias imageviewer exec sdorfehs -c "vselect 4" -c "exec $IMAGEVIEWER"
alias lock exec slock
alias mixer exec $TERMEXEC $MIXER
alias office exec sdorfehs -c "vselect 3" -c "exec $OFFICE"
alias player exec sdorfehs -c "vselect 2" -c "exec $PLAYER"
alias poweroff exec systemctl poweroff
alias printscreen exec scrot $HOME/.local/share/pictures/screenshots/%c-debian.png 
alias reboot exec systemctl reboot
alias suspend exec slock systemctl suspend -i
alias systop exec sdorfehs -c "vselect 4" -c "exec $TERMEXEC $SYSTOP"
alias telegram exec sdorfehs -c "vselect 1" -c "exec telegram-desktop"
alias termexec exec $TERMEXEC
alias terminal exec $TERMINAL
alias voldown exec volnoti -5%
alias volmute exec volnoti toggle
alias volup exec volnoti +5%
alias yt exec sdorfehs -c "vselect 2" -c "exec $YT"

##################
#ALIASES END HERE#
#######################################
#GENERAL SETTINGS VARIABLES BEGIN HERE#
#######################################
#Appearance#
############

set barbordercolor #1D1F1F
set bgcolor #3B3E3F
set bwcolor #0C3662
set fgcolor #EEEEEC
set font "Terminess Nerd Font:size=12:style=bold"
set fwcolor #145BA6

#################################################
#Make Classic Terminals (Rxvt, ST, UXTerm/XTerm)#
#honor their respective frame sizes##############
####################################

set ignoreresizehints 1

##################
#Message Settings#
##################

set msgwait 2
set startupmessage 0

##################################
#Number of Virtual Screens to Use#
##################################

set vscreens 5

###########################
#Position & Scaling Tweaks#
###########################

set barinpadding 1
set barborder 1
set bargravity sw
set barpadding 5 5
set barsticky 0
set border 1
set gap 0
set onlyborder 0
set padding 0 0 0 0
set transgravity nw 

############################################
#Set the "Rudeness" Level for Windows Which#
#Tend to Follow Their Own Explicit Behavior#
##############################################
#13 Should Keep Things Mild, Yet Flexible for#
#"Weirder" Window Behavior####################
##########################

# set rudeness 13

#####################################
#GENERAL SETTINGS VARIABLES END HERE#
#####################################
#CUSTOM KEYMAPS BEGIN HERE#
###########################

newkmap execterm
newkmap helpkeys
newkmap information
newkmap powersession
newkmap shortcuts

####################
#Access the Keymaps#
####################

definekey top s-End readkey powersession
definekey top s-i readkey information
definekey top s-question readkey helpkeys
definekey top s-Return readkey execterm
definekey top s-s readkey shortcuts

#########################
#CUSTOM KEYMAPS END HERE#
########################################
#GENERIC KEYBINDING SETTINGS BEGIN HERE#
########################################
#C: Control Key##
#M: Alt/Mod1 Key######
#s: Super/Windows Key#
######################
#Escape#
########

escape s-grave

##########
#ExecTerm#
##########

definekey execterm colon colon
definekey execterm Escape abort
definekey execterm Menu exec
definekey execterm M-Return colon termexec 
definekey execterm Return terminal

#########
#General#
#########

bind Escape abort
definekey information M-v version
definekey information m lastmsg
definekey top Print printscreen

######
#Help#
######

definekey helpkeys Escape abort
definekey helpkeys e help execterm
definekey helpkeys h help helpkeys
definekey helpkeys i help information
definekey helpkeys r help root
definekey helpkeys S help powersession
definekey helpkeys s help shortcuts
definekey helpkeys t help top

#################
#Power & Session#
#################

definekey powersession End quit
definekey powersession Escape abort
definekey powersession F5 restart
definekey powersession M-End poweroff
definekey powersession M-F5 reboot
definekey powersession M-Pause suspend
definekey powersession Pause lock

###########
#Shortcuts#
###########

definekey shortcuts at exec timeshift-launcher
definekey shortcuts D discord
definekey shortcuts d echodate
definekey shortcuts End systop
definekey shortcuts Escape abort
definekey shortcuts e editor
definekey shortcuts i imageviewer
definekey shortcuts o office
definekey shortcuts t telegram
definekey shortcuts u echouname
definekey shortcuts y yt

##############################
