###########################################
#Welcome to Sdorfehs! Refer to the manpage#
#for additional configuration options.#####
#######################################
#ADDHOOKS BEGIN HERE#
##################################
#Attach Commands to Random Events#
########################################
#Give me a Rundown of Available Windows#
#After I Have Switched Focus############
#############################

addhook switchframe windows
addhook switchwin windows

#############################
#Tell Me Which Screen I'm On#
#############################

addhook switchvscreen vscreens

###################
#ADDHOOKS END HERE#
####################
#ALIASES BEGIN HERE#
################################################
#Useful for stringing together complex commands#
##################################################################
#Dependencies: Volnoti script requires dunst and pulseaudio-utils#
##################################################################

alias editor exec TERMEXEC $EDITOR
alias lock exec slock
alias poweroff exec systemctl poweroff
alias reboot exec systemctl reboot
alias suspend exec slock systemctl suspend -i
alias systop exec $TERMEXEC $SYSTOP
alias voldown exec volnoti -5%
alias volmute exec volnoti toggle
alias volup exec volnoti +5%

##################
#ALIASES END HERE#
#######################################
#GENERAL SETTINGS VARIABLES BEGIN HERE#
#######################################
#Appearance#
############

set barbordercolor #1D1F1F
set bgcolor #3B3E3F
set bwcolor #0C3662
set fgcolor #EEEEEC
set font "Terminess Nerd Font:size=12:style=bold"
set fwcolor #145BA6

#################################################
#Make Classic Terminals (Rxvt, ST, UXTerm/XTerm)#
#honor their respective frame sizes##############
####################################

set ignoreresizehints 1

##################
#Message Settings#
##################

set msgwait 2
set startupmessage 0

##################################
#Number of Virtual Screens to Use#
##################################

set vscreens 5

###########################
#Position & Scaling Tweaks#
###########################

set barinpadding 1
set barborder 1
set bargravity sw
set barpadding 5 5
set barsticky 0
set border 1
set gap 0
set onlyborder 0
set padding 0 0 0 0
set transgravity c

############################################
#Set the "Rudeness" Level for Windows Which#
#Tend to Follow Their Own Explicit Behavior#
##############################################
#13 Should Keep Things Mild, Yet Flexible for#
#"Weirder" Window Behavior####################
##########################

set rudeness 13

#####################################
#GENERAL SETTINGS VARIABLES END HERE#
#####################################
#CUSTOM KEYMAPS BEGIN HERE#
###########################

newkmap execterm
newkmap helpkeys
newkmap information
newkmap powersession
newkmap shortcuts

####################
#Access the Keymaps#
####################

definekey top s-End readkey powersession
definekey top s-i readkey information
definekey top s-question readkey helpkeys
definekey top s-Return readkey execterm
definekey top s-s readkey shortcuts

#########################
#CUSTOM KEYMAPS END HERE#
########################################
#GENERIC KEYBINDING SETTINGS BEGIN HERE#
########################################
#C: Control Key##
#M: Alt/Mod1 Key######
#s: Super/Windows Key#
######################
#Escape#
########

escape s-grave

##########
#ExecTerm#
##########

definekey execterm colon colon
definekey execterm Menu exec
definekey execterm M-Return colon exec $TERMEXEC 
definekey execterm Return exec $TERMINAL

#########
#General#
#########

bind C-a abort
definekey information M-v version
definekey information m lastmsg
definekey top Print exec scrot $HOME/.local/share/pictures/screenshots/%c-debian.png

######
#Help#
######

definekey helpkeys h help helpme
definekey helpkeys i help information
definekey helpkeys r help root
definekey helpkeys s help session
definekey helpkeys t help top

#################
#Power & Session#
#################

definekey session End quit
definekey session F5 restart
definekey session M-End poweroff
definekey session M-F5 reboot
definekey session M-Pause suspend
definekey session Pause lock

###########
#Shortcuts#
###########

definekey shortcuts a exec armcord
definekey shortcuts at exec pkexec timeshift-gtk
definekey shortcuts d exec sdorfehs -c "echo `date`"
definekey shortcuts End systop
definekey shortcuts e exec editor
definekey shortcuts f exec freetube
definekey shortcuts o exec $OFFICE
definekey shortcuts t exec telegram-desktop
definekey shortcuts u exec sdorfehs -c "echo `uname -a`"

##############################
#GENERIC KEYBINDINGS END HERE#
##########################################
#WINDOW MANAGEMENT KEYBINDINGS BEGIN HERE#
###############################################
#Banish the Xcursor to the bottom-right corner#
################################################
#NOTE: Programs like xbanish automatically hide#
#the xcursor for you, but doing so can get rid###
#of useful features, like waitcursor on keymap.#
#changing.######################################
###########

definekey top C-s-b banish

##########################################
#Correct, Delete, Kill, Remove, & Restore#
##########################################

bind Delete kill
bind M-Delete remove
bind o only
bind R redo
bind r redisplay
bind U undo

#############
#Information#
#############

definekey information c curframe
definekey information i info
definekey information t title
definekey information v vscreens
definekey information w windows

########
#Moving#
########

bind at vmove

###########
#Selection#
###########

bind S select

###########
#Splitting#
###########

bind h hsplit
bind v vsplit

#################
#Sticky/Unsticky#
#################

bind asterisk stick
bind M-asterisk unstick

##################
#Switching (Root)#
##################

bind braceleft prevscreen
bind braceright nextscreen
bind bracketleft prev
bind bracketright next
bind C cprev
bind c cnext
bind i inext
bind M-c cother
bind M-i iprev
bind S swap

#################
#Switching (Top)#
#################

definekey top s-0 vselect 0
definekey top s-1 vselect 1
definekey top s-2 vselect 2
definekey top s-3 vselect 3
definekey top s-4 vselect 4

########################################
#WINDOW MANAGEMENT KEYBINDINGS END HERE#
