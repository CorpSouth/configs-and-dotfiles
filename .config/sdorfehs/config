#KEYBINDING SETTINGS BEGIN HERE#
################################
#C: Control Key#
#M: Alt/Mod1 Key######
#s: Super/Windows Key#
######################
#Escape & Exec#
###############

bind Menu exec
escape s-grave

########################
#Focusing (Numpad, Top)#
########################

definekey top s-KP_Down focusdown
definekey top s-KP_Left focusleft
definekey top s-KP_Right focusright
definekey top s-KP-Up focusup

#########
#General#
#########

bind C-s-BackSpace undo
bind C-a abort
bind C-Delete remove
bind C-s-F5 restart
bind C-Menu windows
bind C-M-End quit
bind C-M-k kill
bind C-s-Return redo
bind C-s-s select
bind C-s-T colon exec $TERMEXEC
bind C-s-Delete delete
bind M-question help top
bind M-s-f curframe
bind M-s-i info
bind M-s-r redisplay
bind M-s-t title
bind M-question help top
bind M-v version
bind s-Menu vscreens

###########
#Launchers#
###########

bind s-A armcord
bind s-B exec pkexec timeshift-gtk
bind s-d exec sdorfehs -c "echo `date`"
