###########################################
#Welcome to Sdorfehs! Refer to the manpage#
#for additional configuration options.#####
#######################################
#ALIASES BEGIN HERE#
################################################
#Useful for stringing together complex commands#
#################################################
#Hint: Use aliases for launching applications on#
#other available vscreens. Results may vary.#####
#############################################

alias armcord exec sdorfehs -c "vselect 1" -c "exec armcord"
alias browser exec sdorfehs -c "vselect 0" -c "exec $BROWSER"
alias calculator exec $TERMEXEC $CALCULATOR
alias editor exec sdorfehs -c "vselect 6" -c "exec $TERMEXEC $EDITOR"
alias filepicker exec filepicker.sh
alias mail exec sdorfehs -c "vselect 0" -c "exec $MAIL"
alias mixer exec $TERMEXEC $MIXER
alias office exec sdorfehs -c "vselect 6" -c "exec $OFFICE"
alias player exec sdorfehs -c "vselect 3" -c "exec $PLAYER"
alias suspend exec slock systemctl suspend -i
alias taskmanager exec sdorfehs -c "vselect 2" -c "exec $TERMEXEC $TASKMANAGER"
alias telegram-desktop exec sdorfehs -c "vselect 1" -c "exec telegram-desktop"
alias term exec $TERMINAL
alias voldown exec pactl set-sink-volume @DEFAULT_SINK@ -5%
alias volmute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
alias volup exec pactl set-sink-volume @DEFAULT_SINK@ +5%
alias youtube exec sdorfehs -c "vselect 3" -c "exec freetube"

##################
#ALIASES END HERE#
#######################################
#GENERAL SETTINGS VARIABLES BEGIN HERE#
#######################################

set barinpadding 0
set barborder 2
set barbordercolor #1D1F1F 
set bargravity c
set bgcolor #3B3E3F
set barpadding 6 6
set barsticky 0
set border 2
set bwcolor #202223
set fgcolor #EEEEEC
set font "Terminess Nerd Font:size=12:style=bold"
set fwcolor #145BA6
set gap 0
set ignoresizehints 1
set msgwait 4
set onlyborder 1
set padding 0 0 0 0
#set rudeness 12
set startupmessage 0
set transgravity c
set vscreens 7

#####################################
#GENERAL SETTINGS VARIABLES END HERE#
