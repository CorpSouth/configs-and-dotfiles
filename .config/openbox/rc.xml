<?xml version="1.0" encoding="UTF-8"?>
<!-- Do not edit this file, it will be overwritten on install.
        Copy the file to $HOME/.config/openbox/ instead. -->
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <resistance>
    <strength>10</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>
  <focus>
    <focusNew>yes</focusNew>
    <!-- always try to focus new windows when they appear. other rules do
       apply -->
    <followMouse>no</followMouse>
    <!-- move focus to a window when you move the mouse into it -->
    <focusLast>yes</focusLast>
    <!-- focus the last used window when changing desktops, instead of the one
       under the mouse pointer. when followMouse is enabled -->
    <underMouse>no</underMouse>
    <!-- move focus under the mouse, even when the mouse is not moving -->
    <focusDelay>200</focusDelay>
    <!-- when followMouse is enabled, the mouse must be inside the window for
       this many milliseconds (1000 = 1 sec) before moving focus to it -->
    <raiseOnFocus>no</raiseOnFocus>
  </focus>
  <!-- when followMouse is enabled, and a window is given focus by moving the
       mouse into it, also raise the window -->
  <placement>
    <policy>Smart</policy>
    <!-- 'Smart' or 'UnderMouse' -->
    <center>yes</center>
    <!-- whether to place windows in the center of the free area found or
       the top left corner -->
    <monitor>Any</monitor>
    <primaryMonitor/>
  </placement>
  <!-- with Smart placement on a multi-monitor system, try to place new windows
       on: 'Any' - any monitor, 'Mouse' - where the mouse is, 'Active' - where
       the active window is -->
  <theme>
    <name>oomox-EndeavourOS Arc Dark</name>
    <titleLayout>NDSLIMC</titleLayout>
    <!--       available characters are NDSLIMC, each can occur at most once.
      N: window icon
      L: window label (AKA title).
      I: iconify
      M: maximize
      C: close
      S: shade (roll up/down)
      D: omnipresent (on all desktops).
  -->
    <keepBorder>yes</keepBorder>
    <animateIconify>no</animateIconify>
    <font place="ActiveWindow">
      <name>Lato</name>
      <size>10</size>
      <!-- font size in points -->
      <weight>Bold</weight>
      <!-- 'bold' or 'normal' -->
      <slant>Normal</slant>
    </font>
    <!-- 'italic' or 'normal' -->
    <font place="InactiveWindow">
      <name>Lato</name>
      <size>10</size>
      <!-- font size in points -->
      <weight>Bold</weight>
      <!-- 'bold' or 'normal' -->
      <slant>Normal</slant>
    </font>
    <!-- 'italic' or 'normal' -->
    <font place="MenuHeader">
      <name>Lato Medium</name>
      <size>10</size>
      <!-- font size in points -->
      <weight>Normal</weight>
      <!-- 'bold' or 'normal' -->
      <slant>Normal</slant>
    </font>
    <!-- 'italic' or 'normal' -->
    <font place="MenuItem">
      <name>Lato Medium</name>
      <size>10</size>
      <!-- font size in points -->
      <weight>Normal</weight>
      <!-- 'bold' or 'normal' -->
      <slant>Normal</slant>
    </font>
    <!-- 'italic' or 'normal' -->
    <font place="ActiveOnScreenDisplay">
      <name>Lato</name>
      <size>10</size>
      <weight>Bold</weight>
      <slant>Bold</slant>
    </font>
    <font place="InactiveOnScreenDisplay">
      <name>Lato</name>
      <size>8</size>
      <weight>Normal</weight>
      <slant>Normal</slant>
    </font>
  </theme>
  <!-- 'italic' or 'normal' -->
  <desktops>
    <!-- this stuff is only used at startup, pagers allow you to change them
       during a session

       these are default values to use when other ones are not already set
       by other applications, or saved in your session

       use obconf if you want to change these without having to log out
       and back in -->
    <number>6</number>
    <firstdesk>1</firstdesk>
    <names>
      <name>.NET</name>
      <name>CHAT</name>
      <name>PLAY</name>
      <name>TERM</name>
      <name>UTIL</name>
      <name>WORK</name>
    </names>
    <!-- set names up here if you want to, like this:
    <name>desktop 1</name>
    <name>desktop 2</name>
    -->
    <popupTime>875</popupTime>
  </desktops>
  <!-- The number of milliseconds to show the popup for when switching
       desktops.  Set this to 0 to disable the popup. -->
  <resize>
    <drawContents>yes</drawContents>
    <popupShow>Nonpixel</popupShow>
    <!-- 'Always', 'Never', or 'Nonpixel' (xterms and such) -->
    <popupPosition>Center</popupPosition>
    <!-- 'Center', 'Top', or 'Fixed' -->
    <popupFixedPosition>
      <!-- these are used if popupPosition is set to 'Fixed' -->
      <x>10</x>
      <!-- positive number for distance from left edge, negative number for
         distance from right edge, or 'Center' -->
      <y>10</y>
    </popupFixedPosition>
  </resize>
  <!-- You can reserve a portion of your screen where windows will not cover when
     they are maximized, or when they are initially placed.
     Many programs reserve space automatically, but you can use this in other
     cases. -->
  <margins>
    <top>0</top>
    <bottom>0</bottom>
    <left>0</left>
    <right>0</right>
  </margins>
  <!-- 'Left', 'Middle', 'Right' -->
  <!-- APPLICATION RULES START HERE -->
  <applications>
    <!-- Defaults to maximize for normal windows, otherwise force center -->
    <application type="normal">
      <maximized>true</maximized>
      <position force="yes">
        <x>center</x>
        <y>center</y>
      </position>
    </application>
    <!-- Exclude from maximize -->
    <application class="Galculator">
      <maximized>false</maximized>
    </application>
    <application class="Gimp">
      <maximized>false</maximized>
    </application>
    <application class="Lxappearance">
      <maximized>false</maximized>
    </application>
    <application class="Obconf">
      <maximized>false</maximized>
    </application>
    <application class="Pavucontrol">
      <maximized>false</maximized>
    </application>
    <application class="Xarchiver">
      <maximized>false</maximized>
    </application>
    <application class="XCalc">
      <maximized>false</maximized>
    </application>
    <application class="XClock">
      <maximized>false</maximized>
    </application>
    <application class="Yad*">
      <maximized>false</maximized>
    </application>
    <!-- Start applications on the following desktops -->
    <!-- Desktop 1, The Usual Business -->
    <application class="librewolf*">
      <desktop>1</desktop>
    </application>
    <application class="thunderbird*">
      <desktop>1</desktop>
    </application>
    <!-- Desktop 2, Chew the Fat -->
    <application class="TelegramDesktop*">
      <desktop>2</desktop>
    </application>
    <application class="WebCord*">
      <desktop>2</desktop>
    </application>
    <!-- Desktop 3, Have Some Fun -->
    <application class="FreeTube*">
      <desktop>3</desktop>
    </application>
    <application class="Lxmusic*">
      <desktop>3</desktop>
    </application>
    <application class="mpv*">
      <desktop>3</desktop>
    </application>
    <!-- Desktop 4, Enter the Matrix -->
    <application class="UXTerm*">
      <desktop>4</desktop>
    </application>
    <application class="XTerm*">
      <desktop>4</desktop>
    </application>
    <!-- Desktop 5, Handy Stuff -->
    <application class="BleachBit">
      <desktop>5</desktop>
    </application>
    <application class="Lxappearance">
      <desktop>5</desktop>
    </application>
    <application class="Lxrandr">
      <desktop>5</desktop>
    </application>
    <application class="Obconf">
      <desktop>5</desktop>
    </application>
    <!-- Desktop 6, For Getting Stuff Done -->
    <application class="Inkscape*">
      <desktop>6</desktop>
    </application>
    <application class="libreoffice-startcenter">
      <desktop>6</desktop>
    </application>
    <application class="Oomox*">
      <desktop>6</desktop>
    </application>
    <application class="Soffice*">
      <desktop>6</desktop>
    </application>
    <!-- Workaround for applications not focusing upon launching -->
    <application class="*" name="*" role="*" title="*" type="*">
      <focus>yes</focus>
    </application>
    <!-- Workaround for applications not honoring decoration settings -->
    <application class="*" name="*" role="*" title="*" type="*">
      <decor>no</decor>
    </application>
  </applications>
  <!-- APPLICATION RULES END HERE -->
  <keyboard>
    <chainQuitKey>Escape</chainQuitKey>
    <!-- APPLICATION KEYBINDINGS AND KEYCHAINS START HERE-->
    <!-- Keychains for power and session control -->
    <keybind key="C-S-W-End">
      <keybind key="l">
        <action name="Execute">
	  <command>slock</command>
        </action>
      </keybind>
      <keybind key="r">
	<action name="Execute">
	  <command>systemctl reboot</command>
	</action>
      </keybind>
      <keybind key="s">
        <action name="Execute">
          <command>systemctl poweroff</command>
        </action>
      </keybind>
      <keybind key="x">
        <action name="Execute">
          <command>pkill -KILL -u corpsouth</command>
        </action>
      </keybind>
    </keybind>
    <!-- Keychains for restarting programs and services, or restoring and updating settings -->
    <keybind key="W-F5">      
      <keybind key="F5">
   	<action name="Restart"/>
      </keybind>
      <keybind key="Menu">
	<action name="Execute">
	  <command>mmaker -f --no-debian --no-legacy openbox -t xterm</command>
        </action>
      </keybind>
      <keybind key="r">
	<action name="Reconfigure"/>
      </keybind>
      <keybind key="x">
	<action name="Execute">
          <command>xrdb -merge /home/corpsouth/.config/X11/xresources</command>
        </action>
      </keybind>
    </keybind>
    <!-- Launch the terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute">
        <command>uxterm</command>
      </action>
    </keybind>
    <!-- Menu -->
    <keybind key="C-Menu">
      <action name="ShowMenu">
        <menu>client-menu</menu>
      </action>
    </keybind>
    <keybind key="A-C-Menu">
      <action name="ShowMenu">
        <menu>client-list-combined-menu</menu>
      </action>
    </keybind>
    <keybind key="W-Menu">
      <action name="ShowMenu">
        <menu>root-menu</menu>
      </action>
    </keybind>
    <!-- Screenshot -->
    <keybind key="Print">
      <action name="Execute">
	<command>scrot /home/corpsouth/.local/share/screenshots/%c-enos-arm.png</command>
      </action>
    </keybind>
    <!-- XF86 common shortcuts -->
    <keybind key="XF86Calculator">
      <action name="Execute">
        <command>xcalc</command>
      </action>
    </keybind>
    <keybind key="XF86Explorer">
      <action name="Execute">
        <command>yad --center --file</command>
      </action>
    </keybind>
    <keybind key="XF86HomePage">
      <action name="Execute">
        <command>librewolf</command>
      </action>
    </keybind>
    <keybind key="XF86Mail">
      <action name="Execute">
        <command>thunderbird</command>
      </action>
    </keybind>
    <keybind key="XF86Tools">
      <action name="Execute">
        <command>mpv --player-operation-mode=pseudo-gui</command>
      </action>
    </keybind>
    <!-- XF86 volume keys -->
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute">
        <command>pactl set-sink-volume @DEFAULT_SINK@ -5%</command>
      </action>
    </keybind>
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute">
        <command>pactl set-sink-volume @DEFAULT_SINK@ +5%</command>
      </action>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute">
        <command>pactl set-sink-mute @DEFAULT_SINK@ toggle</command>
      </action>
    </keybind>
    <!-- APPLICATION KEYBINDINGS AND KEYCHORDS END HERE -->
    <!-- DESKTOP NAVIGATION KEYBINDINGS START HERE -->
    <!-- Keybinds for desktop switching using the HJKL keys (vim-like) -->
    <keybind key="A-W-KP_Down">
      <action name="GoToDesktop">
        <to>down</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="A-W-KP_Left">
      <action name="GoToDesktop">
        <to>left</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="A-W-KP_Right">
      <action name="GoToDesktop">
        <to>right</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="A-W-KP_Up">
      <action name="GoToDesktop">
        <to>up</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <!-- Keybinds for desktop switching using the bracket keys -->
    <keybind key="A-W-bracketright">
      <action name="GoToDesktop">
        <to>next</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="A-W-bracketleft">
      <action name="GoToDesktop">
        <to>previous</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <!-- Keybinds for desktop switching using the number keys -->
    <keybind key="W-1">
      <action name="GoToDesktop">
        <to>1</to>
      </action>
    </keybind>
    <keybind key="W-2">
      <action name="GoToDesktop">
        <to>2</to>
      </action>
    </keybind>
    <keybind key="W-3">
      <action name="GoToDesktop">
        <to>3</to>
      </action>
    </keybind>
    <keybind key="W-4">
      <action name="GoToDesktop">
        <to>4</to>
      </action>
    </keybind>
    <keybind key="W-5">
      <action name="GoToDesktop">
        <to>5</to>
      </action>
    </keybind>
    <keybind key="W-6">
      <action name="GoToDesktop">
        <to>6</to>
      </action>
    </keybind>
    <!-- DESKTOP NAVIGATION KEYBINDINGS END HERE -->
    <!-- FOCAL KEYBINDINGS START HERE -->
    <!-- Cycle the next/previous window using Tab -->
    <keybind key="W-Tab">
      <action name="NextWindow">
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <keybind key="S-W-Tab">
      <action name="PreviousWindow">
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <!-- Cycle windows using bracket keys -->
    <keybind key="W-bracketleft">
       <action name="PreviousWindow">
         <finalactions>
           <action name="Focus"/>
           <action name="Raise"/>
           <action name="Unshade"/>
        </finalactions>
       </action>
    </keybind>
    <keybind key="W-bracketright">
      <action name="NextWindow">
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <!-- Directionally cycle window focus using the numpad keys 2468 -->
    <keybind key="W-KP_Down">
      <action name="DirectionalCycleWindows">
        <direction>down</direction>
      </action>
    </keybind>
    <keybind key="W-KP_Left">
      <action name="DirectionalCycleWindows">
        <direction>left</direction>
      </action>
    </keybind>
    <keybind key="W-KP_Right">
      <action name="DirectionalCycleWindows">
        <direction>right</direction>
      </action>
    </keybind>
    <keybind key="W-KP_Up">
      <action name="DirectionalCycleWindows">
        <direction>up</direction>
      </action>
    </keybind>
    <!-- FOCAL KEYBINDINGS END HERE -->
    <!-- GENERAL WINDOW MANAGEMENT KEYBINDINGS START HERE -->
    <!-- Centering windows -->
    <keybind key="W-c">
      <action name="MoveResizeTo">
        <x>center</x>
        <y>center</y>
      </action>
    </keybind>
    <!-- Closing/killing windows -->
    <keybind key="W-Delete">
      <action name="Close">
      </action>
    </keybind>
    <!-- Iconifying windows -->
    <keybind key="W-i">
      <action name="Iconify"/>
    </keybind>
    <!-- Lowering/raising windows -->
    <keybind key="A-W-r">
      <action name="RaiseLower"/>
    </keybind>
    <keybind key="W-Down">
      <action name="FocusToBottom"/>
      <action name="Lower"/>
      <action name="Unfocus"/>
    </keybind>
    <keybind key="W-Up">
      <action name="Focus"/>
      <action name="Raise"/>
    </keybind>
    <!-- Moving/resizing windows -->
    <keybind key="A-W-m">
      <action name="Move"/>
    </keybind>
    <keybind key="W-r">
      <action name="Resize"/>
    </keybind>
    <!-- Toggle window settings and states -->
    <keybind key="A-W-d">
      <action name="ToggleDecorations"/>
    </keybind>
    <keybind key="W-d">
      <action name="ToggleShowDesktop"/>
    </keybind>
    <keybind key="W-f">
      <action name="ToggleFullscreen"/>
    </keybind>
    <keybind key="W-m">
      <action name="ToggleMaximize"/>
      <action name="Undecorate"/>
    </keybind>
    <keybind key="W-o">
      <action name="ToggleOmnipresent"/>
    </keybind>
    <keybind key="W-s">
      <action name="ToggleShade"/>
    </keybind>
    <!-- GENERAL WINDOW MANAGEMENT KEYBINDINGS END HERE -->
    <!-- WINDOW DESKTOP RELOCATION KEYBINDINGS START HERE -->
    <!-- Window desktop relocation using the numpad -->
    <keybind key="S-W-KP_Down">
      <action name="SendToDesktop">
        <to>down</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="S-W-KP_Left">
      <action name="SendToDesktop">
        <to>left</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="S-W-KP_Right">
      <action name="SendToDesktop">
        <to>right</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <keybind key="S-W-KP_Up">
      <action name="SendToDesktop">
        <to>up</to>
        <wrap>no</wrap>
      </action>
    </keybind>
    <!-- Send window to the next/previous desktop -->
    <keybind key="S-W-bracketleft">
      <action name="SendToDesktop">
        <to>previous</to>
      </action>
    </keybind>
    <keybind key="S-W-bracketright">
      <action name="SendToDesktop">
        <to>next</to>
      </action>
    </keybind>
    <!-- Send window to a targeted desktop -->
    <keybind key="S-W-1">
      <action name="SendToDesktop">
        <follow>no</follow>
        <to>1</to>
      </action>
    </keybind>
    <keybind key="S-W-2">
      <action name="SendToDesktop">
        <follow>no</follow>
        <to>2</to>
      </action>
    </keybind>
    <keybind key="S-W-3">
      <action name="SendToDesktop">
        <follow>no</follow>
        <to>3</to>
      </action>
    </keybind>
    <keybind key="S-W-4">
      <action name="SendToDesktop">
        <follow>no</follow>
        <to>4</to>
      </action>
    </keybind>
    <keybind key="S-W-5">
      <action name="SendToDesktop">
        <follow>no</follow>
        <to>5</to>
      </action>
    </keybind>
    <!-- WINDOW DESKTOP RELOCATION KEYBINDINGS END HERE -->
    <!-- WINDOW GROWING KEYCHAINS START HERE -->
    <keybind key="W-g">
      <keybind key="f">
	<action name="GrowToFill"/>
      </keybind>
      <keybind key="KP_Down">
	<action name="GrowToEdge">
	  <direction>south</direction>
	</action>
      </keybind>
      <keybind key="KP_Left">
	<action name="GrowToEdge">
	  <direction>west</direction>
	</action>
      </keybind>
      <keybind key="KP_Right">
	<action name="GrowToEdge">
	  <direction>east</direction>
	</action>
      </keybind>
      <keybind key="KP_Up">
	<action name="GrowToEdge">
	  <direction>north</direction>
	</action>
      </keybind>
    </keybind>
    <!-- WINDOW GROWING KEYCHAINS END HERE -->
    <!-- WINDOW SHRINKING KEYCHAINS START HERE -->
    <keybind key="A-W-s">
      <keybind key="KP_Down">
	<action name="ShrinkToEdge">
	  <direction>south</direction>
	</action>
      </keybind>
      <keybind key="KP_Left">
	<action name="ShrinkToEdge">
	  <direction>west</direction>
	</action>
      </keybind>
      <keybind key="KP_Right">
	<action name="ShrinkToEdge">
	  <direction>east</direction>
	</action>
      </keybind>
      <keybind key="KP_Up">
	<action name="ShrinkToEdge">
	  <direction>north</direction>
	</action>
      </keybind>
    </keybind>
    <!-- WINDOW SHRINKING KEYCHAINS END HERE -->
    <!-- WINDOW SNAPPING KEYBINDINGS START HERE -->
    <!-- Aside -->
    <keybind key="C-W-Down">
      <action name="MoveToEdge">
	<direction>south</direction>
      </action>
    </keybind>
     <keybind key="C-W-Left">
      <action name="MoveToEdge">
	<direction>west</direction>
      </action>
    </keybind>
    <keybind key="C-W-Right">
      <action name="MoveToEdge">
	<direction>east</direction>
      </action>
    </keybind>
    <keybind key="C-W-Up">
      <action name="MoveToEdge">
	<direction>north</direction>
      </action>
    </keybind>
    <!-- Corner -->
    <keybind key="C-W-KP_1">
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MoveResizeTo">
        <x>0</x>
        <y>50%</y>
        <width>50%</width>
        <height>50%</height>
      </action>
    </keybind>
    <keybind key="C-W-KP_3">
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MoveResizeTo">
        <x>50%</x>
        <y>50%</y>
        <width>50%</width>
        <height>50%</height>
      </action>
    </keybind>
    <keybind key="C-W-KP_7">
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MoveResizeTo">
        <x>0</x>
        <y>0</y>
        <width>50%</width>
        <height>50%</height>
      </action>
    </keybind>
    <keybind key="C-W-KP_9">
      <action name="Undecorate"/>
      <action name="UnmaximizeFull"/>
      <action name="MoveResizeTo">
        <x>50%</x>
        <y>0</y>
        <width>50%</width>
        <height>50%</height>
      </action>
    </keybind>
    <!-- Edge -->
    <keybind key="C-W-KP_Down">      
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MaximizeHorizontal"/>
      <action name="MoveResizeTo">	
	<height>50%</height>
	<width>100%</width>
      </action>
      <action name="MoveToEdge">
	<direction>south</direction>
      </action>
    </keybind>
    <keybind key="C-W-KP_Left">
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MaximizeVert"/>
      <action name="MoveResizeTo">
	<width>50%</width>
      </action>
      <action name="MoveToEdge">
	<direction>west</direction>
      </action>
    </keybind>
    <keybind key="C-W-KP_Right">
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MaximizeVert"/>
      <action name="MoveResizeTo">
	<height>100%</height>
        <width>50%</width>
      </action>
      <action name="MoveToEdge">
	<direction>east</direction>
      </action>
    </keybind>     
    <keybind key="C-W-KP_Up">      
      <action name="Undecorate"/>
      <action name="Unmaximize"/>
      <action name="MaximizeHorizontal"/>
      <action name="MoveResizeTo">
	<height>50%</height>
        <width>100%</width>
      </action>
      <action name="MoveToEdge">
	<direction>north</direction>
      </action>
    </keybind>
    <!-- WINDOW SNAPPING KEYBINDINGS END HERE -->
  </keyboard>
  <mouse>
    <dragThreshold>8</dragThreshold>
    <!-- number of pixels the mouse must move before a drag begins -->
    <doubleClickTime>200</doubleClickTime>
    <!-- in milliseconds (1000 = 1 second) -->
    <screenEdgeWarpTime>400</screenEdgeWarpTime>
    <!-- Time before changing desktops when the pointer touches the edge of the
       screen while moving a window, in milliseconds (1000 = 1 second).
       Set this to 0 to disable warping -->
    <context name="Frame">
      <mousebind button="A-Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="A-Left" action="Click">
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="A-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="A-Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="A-Right" action="Drag">
        <action name="Resize"/>
      </mousebind>
      <mousebind button="A-Middle" action="Press">
        <action name="Lower"/>
        <action name="FocusToBottom"/>
        <action name="Unfocus"/>
      </mousebind>
      <mousebind button="A-Up" action="Click">
        <action name="DesktopPrevious"/>
      </mousebind>
      <mousebind button="A-Down" action="Click">
        <action name="DesktopNext"/>
      </mousebind>
      <mousebind button="C-A-Up" action="Click">
        <action name="DesktopPrevious"/>
      </mousebind>
      <mousebind button="C-A-Down" action="Click">
        <action name="DesktopNext"/>
      </mousebind>
      <mousebind button="A-S-Up" action="Click">
        <action name="SendToDesktopPrevious"/>
      </mousebind>
      <mousebind button="A-S-Down" action="Click">
        <action name="SendToDesktopNext"/>
      </mousebind>
    </context>
    <context name="Titlebar">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="ToggleMaximizeFull"/>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Lower"/>
        <action name="FocusToBottom"/>
        <action name="Unfocus"/>
      </mousebind>
      <mousebind button="Up" action="Click">
        <action name="Shade"/>
        <action name="FocusToBottom"/>
        <action name="Unfocus"/>
        <action name="Lower"/>
      </mousebind>
      <mousebind button="Down" action="Click">
        <action name="Unshade"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu">
          <menu>client-menu</menu>
        </action>
      </mousebind>
    </context>
    <context name="Top">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>top</edge>
        </action>
      </mousebind>
    </context>
    <context name="Left">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>left</edge>
        </action>
      </mousebind>
    </context>
    <context name="Right">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>right</edge>
        </action>
      </mousebind>
    </context>
    <context name="Bottom">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>bottom</edge>
        </action>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Lower"/>
        <action name="FocusToBottom"/>
        <action name="Unfocus"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu">
          <menu>client-menu</menu>
        </action>
      </mousebind>
    </context>
    <context name="BLCorner">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
    <context name="BRCorner">
