#################################
#  Keyboard Keybindings         #
#################################
#  KEYBINDINGS:                 #
#  4 = mod (windows key)        #
#  S = shift                    #
#  C = control                  #
#  M = meta (alt)               #
#################################
# reload cwm configuration file #
#################################

bind-key 4CS-r restart

##################################
# APPEARANCE SETTINGS START HERE #
##################################

fontname "ubuntu mono"

######################
# borders and colors #
######################

borderwidth 2

color activeborder   "#3465A4"
color urgencyborder  "#448AFF"
color inactiveborder "#14161b"	
color groupborder	 "#729FCF"
color ungroupborder	 "#274164"
color menubg         "#1B1D24"
color menufg         "#3465A4"
color font           "#E3E4E7"
color selfont        "#FFFFFF"

#################
# menu contents #
#################

command '»common«'       'true'
command FileManager      spacefm
command Mail             thunderbird
command SystemMonitor    "urxvt -e btop"
command TerminalEmulator urxvt
command TextEditor       "urxvt -e vim"
command WebBrowser       firefox
command '»system«'       'true'
command KillWindow       xkill
command LockScreen       slock
command Logout           "pkill -KILL -u aln"
command Reboot           sudo init 6
command Shutdown         sudo init 0 

####################
# default keybinds # 
####################

unbind-key all

#################
# menu keybinds #
#################

bind-key 4-Menu    menu-cmd
bind-key C-Menu    menu-window
bind-key M-Menu    menu-exec
bind-key S-Menu    menu-group
bind-key 4C-Menu   menu-window-hidden
bind-key 4M-Menu   menu-exec-wm
bind-key 4S-Menu   menu-ssh

######################
# cycle window focus #
######################

bind-key 4-Tab window-cycle
bind-key 4S-Tab window-rcycle

##########################
# cycle windows in-group #
##########################

bind-key 4M-bracketright window-cycle-ingroup
bind-key 4M-bracketleft	window-rcycle-ingroup

########################
# close or hide window #
########################

bind-key 4-Delete window-close
bind-key 4C-h window-hide

###################
# window snapping #
###################

bind-key 4-KP_Left  window-snap-left
bind-key 4-KP_Right window-snap-right
bind-key 4-KP_Up    window-snap-up
bind-key 4-KP_Down  window-snap-down
bind-key 4-KP_End   window-snap-down-left
bind-key 4-KP_Next  window-snap-down-right
bind-key 4-KP_Home  window-snap-up-left
bind-key 4-KP_Prior window-snap-up-right
    
###########################################################################
# GROUP ASSIGNMENT STARTS HERE                                            #
###########################################################################
# use the xprop command to grab "WM_NAME, WM_CLASS", listed in that order #
###########################################################################

sticky yes

autogroup 1 Firefox 
autogroup 1 thunderbird
autogroup 2 TelegramDesktop
autogroup 2 WebCord
autogroup 4 feh
autogroup 4 mpv
autogroup 5 BleachBit 
autogroup 5 Imager
autogroup 5 Lxappearance
autogroup 5 Spacefm
autogroup 5 XClock
autogroup 6 libreoffice
autogroup 6 XCalc

##########################
# sticky window to group #
##########################

bind-key 4C-s	window-stick

###########################
# group membership toggle #
###########################

bind-key 4-g window-group

################################
# close all windows from group #
################################

bind-key 4M-1 group-close-1
bind-key 4M-2 group-close-2
bind-key 4M-3 group-close-3
bind-key 4M-4 group-close-4
bind-key 4M-5 group-close-5

################
# cycle groups #
################

bind-key 4-bracketright group-cycle
bind-key 4-bracketleft group-rcycle

##############
# view group #
##############

bind-key 4-1 group-only-1 
bind-key 4-2 group-only-2 
bind-key 4-3 group-only-3 
bind-key 4-4 group-only-4 
bind-key 4-5 group-only-5 

#####################
# group view toggle #
#####################

bind-key 4-a group-toggle-all
bind-key 4C-1 group-toggle-1
bind-key 4C-2 group-toggle-2
bind-key 4C-3 group-toggle-3
bind-key 4C-4 group-toggle-4
bind-key 4C-5 group-toggle-5

########################
# move window to group #
########################

bind-key 4S-1 window-movetogroup-1
bind-key 4S-2 window-movetogroup-2
bind-key 4S-3 window-movetogroup-3
bind-key 4S-4 window-movetogroup-4
bind-key 4S-5 window-movetogroup-5

####################
# maximize windows #
####################

bind-key 4-f window-fullscreen
bind-key 4CM-h window-hmaximize
bind-key 4CM-v window-vmaximize

##########
# moving #
##########

moveamount 10

bind-key 4-h window-move-left
bind-key 4-j window-move-down
bind-key 4-k window-move-up
bind-key 4-l window-move-right

######################
# moving alternative #
######################

bind-key 4-Left window-move-left-big
bind-key 4-Down window-move-down-big
bind-key 4-Up window-move-up-big
bind-key 4-Right window-move-right-big

############
# resizing #
############

bind-key 4S-h window-resize-left
bind-key 4S-j window-resize-down
bind-key 4S-k window-resize-up
bind-key 4S-l window-resize-right

########################
# resizing alternative #
########################

bind-key 4S-Left window-resize-left-big
bind-key 4S-Down window-resize-down-big
bind-key 4S-Up window-resize-up-big
bind-key 4S-Right window-resize-right-big

############
# snapping #
############

snapdist 5

bind-key 4-KP_Left  window-snap-left
bind-key 4-KP_Right window-snap-right
bind-key 4-KP_Up    window-snap-up
bind-key 4-KP_Down  window-snap-down
bind-key 4-KP_End   window-snap-down-left
bind-key 4-KP_Next  window-snap-down-right
bind-key 4-KP_Home  window-snap-up-left
bind-key 4-KP_Prior window-snap-up-right

##########
# tiling #
##########

htile 50
vtile 50

bind-key 4M-h window-htile
bind-key 4M-v window-vtile

#####################
# Mouse Keybindings #
#####################
# unbind-mouse all  #
#####################

##########################
# move and resize window #
##########################

bind-mouse 4-1 window-move
bind-mouse 4-3 window-resize

#########################
# hide and lower window #
#########################

bind-mouse 4-2 window-lower
bind-mouse 4S-2 window-hide
