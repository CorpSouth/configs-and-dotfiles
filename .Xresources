#ifdef COLOR
*Customization: -color
#else
*Customization: -mono
#endif

! Base16 Grayscale
#define col0  #101010
#define col1  #7C7C7C
#define col2  #8E8E8E
#define col3  #A0A0A0
#define col4  #686868
#define col5  #747474
#define col6  #868686
#define col7  #B9B9B9
#define col8  #525252
#define col9  #7C7C7C
#define col10 #8E8E8E
#define col11 #A0A0A0
#define col12 #686868
#define col13 #747474
#define col14 #868686
#define col15 #F7F7F7

! colorization
*.foreground:  col7
*.background:  col0
*.cursorColor: col7
*.color0:      col0
*.color1:      col1
*.color2:      col2
*.color3:      col3
*.color4:      col4
*.color5:      col5
*.color6:      col6
*.color7:      col7
*.color8:      col8
*.color9:      col9
*.color10:     col10
*.color11:     col11
*.color12:     col12
*.color13:     col13
*.color14:     col14
*.color15:     col15

! Xclock 
XClock*analog:      false
XClock*Clock.face:  terminus 
XClock*foreground:  col7
XClock*background:  col0
XClock*majorColor:  col15
XClock*minorColor:  col15
XClock*hourColor:   col15
XClock*minuteColor: col15
XClock*secondColor: col15

! Xft
Xft*antialias: true
Xft*hinting:   true
Xft*hintstyle: hintslight
Xft*rgba:      rgb

! URxvt
URxvt*font:             xft:terminus
URxvt*boldFont:         xft:terminus:style=bold
URxvt*italicFont:       xft:terminus:style=italic   
URxvt*cursorBlink:      true
URxvt*cursorUnderline:  true
URxvt.iso14755:         false
URxvt*letterSpace:      1
URxvt*lineSpace:        1
URxvt*scrollWithBuffer: false 
URxvt*scrollBar:        false
Urxvt*scrollBar_right:  false
URxvt*internalBorder:   10 
URxvt*urgentOnBell:     true

! Urxvt keybinds for copy/pasting
URxvt.keysym.Shift-Control-V: eval:paste_clipboard
Rxvt.keysym.Shift-Control-C: eval:selection_to_clipboard
